# Main Breneo API base URL (auth, profile, educations, work-experiences, skills, academy).
# No trailing slash. Default: Railway.
VITE_API_BASE_URL=https://web-production-80ed8.up.railway.app

# RapidAPI Resume Parser integration (Profile page CV import)
# Required: API key. Host/URL can be overridden if your subscribed endpoint differs.
VITE_RESUME_PARSER_RAPIDAPI_KEY=
VITE_RESUME_PARSER_RAPIDAPI_HOST=resume-parsing-api2.p.rapidapi.com
# Endpoint used by CV import (from RapidAPI docs)
VITE_RESUME_PARSER_RAPIDAPI_URL=https://resume-parsing-api2.p.rapidapi.com/processDocument

# Optional: add your other env vars below (Supabase, PostHog, etc.) for local development.
# Do not commit real secrets; use .env (gitignored) for local overrides.

# --- Job aggregator (server-only; used by `npm run dev` Express proxy, never VITE_* / browser) ---
# Must match Django EMPLOYER_POST_SECRET on the aggregator. Never commit real values here.
JOB_AGGREGATOR_EMPLOYER_KEY=
JOB_AGGREGATOR_BASE_URL=https://breneo-job-aggregator.up.railway.app

# Browser employer jobs API base (build-time VITE_* is public — no secrets).
# - Leave UNSET: app uses same origin (e.g. https://dashboard.breneo.app) — that host MUST
#   implement POST/GET/PATCH/DELETE on /api/employer/jobs (BFF proxy). If you get 405, the
#   dashboard server does not expose that route yet — deploy server/employer-jobs-proxy.mjs
#   behind the dashboard domain or point this to a separate BFF origin.
# - Set to a dedicated BFF if employer API is not on the same host:
#   VITE_EMPLOYER_JOBS_API_BASE_URL=https://your-employer-bff.up.railway.app
# Do NOT set to the raw Railway aggregator URL in the browser bundle (403 without X-Employer-Key).
# VITE_EMPLOYER_JOBS_API_BASE_URL=

# Breneo API base for employer profile check in dev proxy — must match VITE_API_BASE_URL / JWT issuer.
# MAIN_API_BASE_URL=

# --- Deploy employer BFF (e.g. Railway) so dashboard / GitHub Pages can call /api/employer/jobs ---
# 1. New Railway service → connect this repo. Start Command: npm run start:bff
# 2. Service Variables (not VITE_*): JOB_AGGREGATOR_EMPLOYER_KEY, JOB_AGGREGATOR_BASE_URL,
#    MAIN_API_BASE_URL (same origin as VITE_API_BASE_URL / JWT issuer).
# 3. Copy the public URL (e.g. https://your-bff.up.railway.app). When building the SPA (CI or local):
#    VITE_EMPLOYER_JOBS_API_BASE_URL=https://your-bff.up.railway.app
# 4. Redeploy dashboard.breneo.app / gh-pages so the bundle includes that URL.
#
# --- GitHub Actions (Pages) — see .github/workflows/deploy-github-pages.yml ---
# Repo → Settings → Secrets and variables → Actions → New repository secret:
#   VITE_EMPLOYER_JOBS_API_BASE_URL = https://your-bff.up.railway.app
#   VITE_API_BASE_URL = https://web-production-80ed8.up.railway.app  (or your main API)
# Repo → Settings → Pages → Source: GitHub Actions (not branch deploy).

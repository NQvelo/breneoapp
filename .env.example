# --- Two backends (do not confuse them) ---
# 1) Main Breneo API — auth, employer profile (/api/employer/profile/), educations, academy, etc.
#    The employer jobs BFF validates JWTs against this host only.
# 2) Job aggregator (public read APIs) — VITE_JOB_API_BASE_URL → https://breneo-job-aggregator.up.railway.app
#    Used for: job search (/api/search, /api/v1/jobs/), logos, public lists. NOT for authenticated employer CRUD.
# 3) Employer BFF (secrets + X-Employer-Key) — either same-origin /api/employer/* (production.mjs) OR
#    VITE_EMPLOYER_JOBS_API_BASE_URL / VITE_EMPLOYER_BFF_URL pointing at a deployed employer-jobs-proxy.
#    Upstream then is JOB_AGGREGATOR_BASE_URL (same host as (2), but paths like /api/employer/companies are proxied).
#
# Suspected wrong URLs in production builds:
# - Calling https://dashboard.breneo.app/api/employer/companies?search=… without a server: static hosts return 404.
# - Setting VITE_EMPLOYER_JOBS_API_BASE_URL=https://breneo-job-aggregator.up.railway.app (browser cannot send X-Employer-Key).
# - Mixing VITE_API_BASE_URL (main Breneo) into employer company/jobs fetches — those use getEmployerJobsApiBaseUrl(), not VITE_API_BASE_URL.

# Main Breneo API (no trailing slash). Prefer VITE_BRENEO_API_BASE_URL (same value; clearer name).
VITE_API_BASE_URL=https://web-production-80ed8.up.railway.app
# VITE_BRENEO_API_BASE_URL=https://web-production-80ed8.up.railway.app

# Job aggregator origin for the SPA (jobService, market data, logos). Prefer VITE_JOB_AGGREGATOR_BASE_URL.
# Server BFF uses JOB_AGGREGATOR_BASE_URL (or VITE_JOB_API_BASE_URL as alias when dotenv loads VITE_*).
# VITE_JOB_AGGREGATOR_BASE_URL=https://breneo-job-aggregator.up.railway.app
# VITE_JOB_API_BASE_URL=https://breneo-job-aggregator.up.railway.app

# RapidAPI Resume Parser integration (Profile page CV import)
# Required: API key. Host/URL can be overridden if your subscribed endpoint differs.
VITE_RESUME_PARSER_RAPIDAPI_KEY=
VITE_RESUME_PARSER_RAPIDAPI_HOST=resume-parsing-api2.p.rapidapi.com
# Endpoint used by CV import (from RapidAPI docs)
VITE_RESUME_PARSER_RAPIDAPI_URL=https://resume-parsing-api2.p.rapidapi.com/processDocument

# Optional: add your other env vars below (Supabase, PostHog, etc.) for local development.
# Do not commit real secrets; use .env (gitignored) for local overrides.

# --- Job aggregator (server-only; used by `npm run dev` Express proxy, never VITE_* / browser) ---
# Must match Django EMPLOYER_POST_SECRET on the aggregator. Never commit real values here.
JOB_AGGREGATOR_EMPLOYER_KEY=
# Same host as VITE_JOB_API_BASE_URL above (server-side; can omit if default is correct).
# Employer job CRUD upstream (BFF forwards GET|PATCH|DELETE /api/employer/jobs/{id} here + X-Employer-Key).
JOB_AGGREGATOR_BASE_URL=https://breneo-job-aggregator.up.railway.app
# Rare: append ?company_id= on GET/PATCH/DELETE job detail upstream (default off; matches Postman path-only).
# AGGREGATOR_JOB_DETAIL_COMPANY_QUERY=1
# Upstream companies API (default /api/employer/companies on JOB_AGGREGATOR_BASE_URL, e.g. Railway).
# Search: GET …/api/employer/companies?search=<term> (e.g. https://breneo-job-aggregator.up.railway.app/api/employer/companies?search=breneo) — via BFF with X-Employer-Key.
# Create: POST …/api/employer/companies (no trailing slash) — BFF then POST …/api/employer/staff-memberships { company_id, external_user_id }.
# Override only if your aggregator uses a different path (default /api/employer/staff-memberships).
# JOB_AGGREGATOR_STAFF_MEMBERSHIPS_PATH=/api/employer/staff-memberships
# Only if an old backend requires staff_user_ids inside company JSON: JOB_AGGREGATOR_EMBED_STAFF_USER_IDS_IN_COMPANY_BODY=1
# BFF forwards: GET /api/industries/, GET/POST /api/employer/companies/*, employer jobs CRUD — all with X-Employer-Key server-side.

# Browser employer BFF base (build-time VITE_* is public — no secrets here).
# Company search & jobs: fetch(`${BASE}/api/employer/companies?search=…`) where BASE = this or same-origin.
# Final upstream after BFF: https://breneo-job-aggregator.up.railway.app/api/employer/… (JOB_AGGREGATOR_BASE_URL on the server).
# - Leave UNSET on hosts that run a Node BFF: BASE = window.location.origin (e.g. Railway app + production.mjs).
# - Leave UNSET on static dashboard.breneo.app: BASE auto-resolves to JOB_AGGREGATOR_BASE_URL (same as VITE_JOB_AGGREGATOR_BASE_URL / VITE_JOB_API_BASE_URL) so requests go to …/api/employer/jobs/{id} on the aggregator, not …/api/employer/* on the CDN host.
# - Static dashboard (e.g. gh-pages): SET one of:
#     VITE_EMPLOYER_JOBS_API_BASE_URL=https://your-employer-bff.up.railway.app
#     VITE_EMPLOYER_BFF_URL=https://your-employer-bff.up.railway.app   (alias; same as above)
#   Deploy employer-jobs-proxy there; never point these at the raw aggregator URL.
# - Do NOT set to VITE_API_BASE_URL (main Breneo) or to breneoapp-production unless that service runs this BFF.
# VITE_EMPLOYER_JOBS_API_BASE_URL=
# VITE_EMPLOYER_BFF_URL=

# Breneo API base for employer profile check in dev proxy — must match VITE_API_BASE_URL / JWT issuer.
# MAIN_API_BASE_URL=

# --- Deploy employer BFF (e.g. Railway) so dashboard / GitHub Pages can call /api/employer/jobs ---
# 1. New Railway service → connect this repo. Start Command: npm run start:bff
# 2. Service Variables (not VITE_*): JOB_AGGREGATOR_EMPLOYER_KEY, JOB_AGGREGATOR_BASE_URL,
#    MAIN_API_BASE_URL (same origin as VITE_API_BASE_URL / JWT issuer).
# 3. Copy the public URL (e.g. https://your-bff.up.railway.app). When building the SPA (CI or local):
#    VITE_EMPLOYER_JOBS_API_BASE_URL=https://your-bff.up.railway.app
# 4. Redeploy dashboard.breneo.app / gh-pages so the bundle includes that URL.

# --- Gemini (server-only; employer-jobs-proxy POST/PATCH job descriptions) ---
# Extracts responsibilities[] and qualifications[] from full_description. Key never goes to the browser.
# Job aggregator API should accept optional: description (short AI summary), Responsibilities[],
# qualifications[] (wire keys; filled from Gemini when GEMINI_API_KEY is set). full_description = full post.
# GEMINI_API_KEY=
# Optional override (default gemini-flash-latest; use gemini-2.0-flash if your project has quota):
# GEMINI_MODEL=gemini-flash-latest

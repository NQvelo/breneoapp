# Breneo main API (JWT + GET /api/employer/profile/). BFF validates PATCH/GET job using this host.
# If you log in against a different backend, set both to that origin (no trailing slash).
# VITE_API_BASE_URL is only for browser → Breneo (axios). Employer jobs/companies still go to localhost in dev
# (Vite proxy → employer-jobs-proxy → JOB_AGGREGATOR_BASE_URL), not to this URL.
MAIN_API_BASE_URL=https://web-production-80ed8.up.railway.app
VITE_API_BASE_URL=https://web-production-80ed8.up.railway.app

# breneo-job-aggregator employer job detail: …/api/employer/jobs/{id}?company_id=<directory company id>
AGGREGATOR_JOB_DETAIL_COMPANY_QUERY=1

# Server-only: local employer-jobs-proxy (npm run dev). Must match Django EMPLOYER_POST_SECRET on the job aggregator.
JOB_AGGREGATOR_EMPLOYER_KEY=breneo2025
JOB_AGGREGATOR_BASE_URL=https://breneo-job-aggregator.up.railway.app
# Leave VITE_EMPLOYER_JOBS_API_BASE_URL unset for local dev (Vite → BFF → breneo-job-aggregator).
